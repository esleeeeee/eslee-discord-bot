DISCORD_TOKEN=replace-with-your-bot-token
# Optional local development only. Leave unset in production for global commands only.
DISCORD_DEV_GUILD_ID=
DATABASE_URL=sqlite+aiosqlite:///./data/eslee_bot.db
LOG_LEVEL=INFO
SCHEDULER_POLL_SECONDS=60

# Optional: one guild/channel only. Existing bot features remain multi-server.
DAILY_SUMMARY_ENABLED=false
DAILY_SUMMARY_GUILD_ID=
DAILY_SUMMARY_SOURCE_CHANNEL_ID=
DAILY_SUMMARY_REPORT_CHANNEL_ID=
GEMINI_API_KEY=
DAILY_SUMMARY_AI_MODEL=gemini-3.5-flash
DAILY_SUMMARY_TIMEZONE=Asia/Seoul
DAILY_SUMMARY_RUN_TIME=00:02
DAILY_SUMMARY_RAW_RETENTION_DAYS=3
DAILY_SUMMARY_MIN_TOTAL_MESSAGES=10
DAILY_SUMMARY_MIN_PARTICIPANTS=2
DAILY_SUMMARY_MIN_USER_MESSAGES=3
DAILY_SUMMARY_MAX_USERS=20
